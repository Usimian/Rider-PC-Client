[Unit]
Description=Rider ToF safety governor (forward-speed cap from rider/tof)
After=network.target mosquitto.service rider-tof.service
Wants=mosquitto.service rider-tof.service

[Service]
User=pi
ExecStart=/home/pi/xgovenv/bin/python /home/pi/rider_tof_safety.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
